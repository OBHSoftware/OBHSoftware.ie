{
  "$schema": "./manifest.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2024-11-28T00:00:00Z",

  "site": {
    "id": "obh-software",
    "name": "OBH Software",
    "tagline": "Innovating industries through sustainable technology solutions.",
    "domain": "obhsoftware.ie",
    "locale": "en-IE",
    "timezone": "Europe/Dublin"
  },

  "branding": {
    "logo": {
      "primary": "/logo.png",
      "light": "/logo.png",
      "dark": "/logo.png",
      "favicon": "/favicon.ico"
    },
    "colors": {
      "primary": "#234E01",
      "secondary": "#1a3501",
      "accent": "#F38B2A",
      "success": "#22c55e",
      "warning": "#fbbf24",
      "error": "#ef4444",
      "text": {
        "primary": "#ffffff",
        "secondary": "rgba(255, 255, 255, 0.8)",
        "muted": "rgba(255, 255, 255, 0.6)"
      },
      "background": {
        "primary": "#234E01",
        "secondary": "#1a3501",
        "card": "rgba(255, 255, 255, 0.05)"
      }
    },
    "fonts": {
      "heading": "Space Grotesk",
      "body": "Work Sans"
    }
  },

  "navigation": {
    "dataFile": "navigation.json",
    "mainNav": [
      { "label": "Industries", "href": "/sectors", "type": "page" },
      { "label": "Services", "href": "/#services", "type": "anchor" },
      { "label": "Projects", "href": "/case-studies", "type": "page" },
      { "label": "About", "href": "/#about", "type": "anchor" },
      { "label": "Contact", "href": "/#contact", "type": "anchor" }
    ],
    "footerSections": ["quickLinks", "services", "sectors", "clients"]
  },

  "pages": {
    "home": {
      "path": "/",
      "title": "OBH Software - Technology Consulting",
      "sections": ["hero", "services", "extendedServices", "whyUs", "pricing", "testimonials", "about", "contact"],
      "dataFiles": {
        "services": "services.json",
        "extendedServices": "extendedServices.json",
        "whyUs": "whyUs.json",
        "pricing": "pricing.json",
        "testimonials": "testimonials.json",
        "about": "about.json"
      }
    },
    "calculator": {
      "path": "/calculator",
      "title": "Project Estimator",
      "dataFile": "calculator.json"
    },
    "sectors": {
      "path": "/sectors",
      "title": "Industries We Serve",
      "dataFile": "sectors.json",
      "detailPath": "/sectors/:slug"
    },
    "services": {
      "path": "/services/:slug",
      "title": "Service Details",
      "dataFile": "serviceDetails.json"
    },
    "partners": {
      "path": "/partners",
      "title": "Our Partners",
      "dataFile": "partners.json",
      "detailPath": "/partners/:slug"
    },
    "products": {
      "path": "/products",
      "title": "Our Platforms",
      "dataFile": "products.json",
      "detailPath": "/products/:slug",
      "subsitePath": "/products/:slug/site"
    },
    "caseStudies": {
      "path": "/case-studies",
      "title": "Our Projects",
      "dataFile": "caseStudies.json",
      "detailPath": "/case-studies/:slug"
    },
    "faq": {
      "path": "/faq",
      "title": "Frequently Asked Questions",
      "dataFile": "faqs.json"
    },
    "clientPortal": {
      "path": "/client-portal",
      "title": "Client Portal",
      "dataFile": "clientPortal.json"
    },
    "resources": {
      "path": "/resources",
      "title": "Resources & Downloads",
      "dataFile": "resources.json"
    },
    "blog": {
      "path": "/insights",
      "title": "Insights & Articles",
      "dataFile": "blog.json",
      "detailPath": "/insights/:slug"
    },
    "process": {
      "path": "/how-we-work",
      "title": "How We Work",
      "dataFile": "process.json"
    },
    "careers": {
      "path": "/careers",
      "title": "Careers",
      "dataFile": "careers.json"
    }
  },

  "subsites": [
    {
      "id": "qmechanic",
      "slug": "qmechanic",
      "name": "qMechanic",
      "externalUrl": "https://qmechanic.autos",
      "status": "external"
    },
    {
      "id": "qhaul",
      "slug": "qhaul",
      "name": "qHaul",
      "path": "/products/qhaul/site",
      "manifestFile": "subsites/qhaul.json",
      "status": "active"
    }
  ],

  "contact": {
    "email": "info@obhsoftware.ie",
    "phone": "+353 87 295 9063",
    "address": {
      "street": "University of Galway",
      "city": "Galway",
      "country": "Ireland"
    },
    "social": {
      "linkedin": "https://linkedin.com/company/obhsoftware"
    }
  },

  "seo": {
    "defaultTitle": "OBH Software - Technology Consulting Ireland",
    "titleTemplate": "%s | OBH Software",
    "defaultDescription": "Custom software, web design and business-process automation. Innovating industries through sustainable technology solutions.",
    "keywords": ["software consulting", "custom software", "web design", "business automation", "Ireland", "Galway", "technology"],
    "ogImage": "/og-image.jpg"
  },

  "legal": {
    "companyName": "OBH Software",
    "registrationNumber": "",
    "vatNumber": "",
    "privacyPolicy": "/privacy",
    "termsOfService": "/terms",
    "cookiePolicy": "/cookies"
  }
}
